# Neon DB Connection Strings
# Use the pooled connection string (with '-pooler' in the hostname) for DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@EP-POOLER-ID.region.aws.neon.tech/dbname?sslmode=require"

# Use the direct connection string (without '-pooler' in the hostname) for DIRECT_URL (for migrations)
DIRECT_URL="postgresql://USER:PASSWORD@EP-ID.region.aws.neon.tech/dbname?sslmode=require"
